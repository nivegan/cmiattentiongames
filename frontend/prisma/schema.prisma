generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daily_funnel {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  event_type   EventType
  game_type_id GameType?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model kalari_games {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode            String
  topic           String?
  content         Json
  difficulty_band Int       @default(1)
  scheduled_for   DateTime  @db.Date
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([mode, scheduled_for], map: "unique_daily_game")
  @@index([mode, scheduled_for], map: "idx_kalari_games_lookup")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_stats {
  id                  String    @id @db.Uuid
  user_id             String    @db.Uuid
  game_type_id        GameType?
  difficulty_band     Float
  score               Int
  is_success          Boolean
  completion_time_sec Int?
  metadata            Json?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daily_scenarios {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  play_date       DateTime @db.Date
  game_type_id    String
  difficulty_band Float    @default(1.0)
  scenario_data   Json
  created_at      DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@unique([play_date, game_type_id], map: "unique_game_per_date")
  @@index([play_date, game_type_id], map: "idx_daily_scenarios_lookup")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_onboarding {
  user_id      String   @id @db.Uuid
  completed_at DateTime @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_feedback {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  nps_score         Int
  improvement_score Int
  comments          String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model weekly_summaries {
  user_id         String    @db.Uuid
  week_start_date DateTime  @db.Date
  payload         Json
  created_at      DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  dismissed_at    DateTime? @db.Timestamptz(6)

  @@id([user_id, week_start_date])
  @@index([user_id], map: "idx_weekly_summaries_user")
}

enum EventType {
  SESSION_START
  GAME_START
  GAME_CLICK
  GAME_COMPLETE
  SESSION_END
}

enum GameStatus {
  COMPLETED
  ABANDONED
  TIMED_OUT
}

enum GameType {
  STEADY_GAZE
  CLEAR_THE_AIR
  EXTRACT_THE_FACTS
  GUT_CHECK
  READ_BETWEEN_DESIGNS
  MENTAL_REFLEX
}
